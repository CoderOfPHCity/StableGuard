# X Layer testnet
RPC_URL=https://xlayer-testnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
CHAIN_ID=195

# Deployer wallet — use a burner/testnet-only key, never your main wallet
PRIVATE_KEY=0xyour_testnet_deployer_private_key

# UNVERIFIED — confirm via scripts/verify-pool-manager.sh before deploying.
# This is the commonly-used deterministic v4-core CREATE2 address; update if
# X Layer testnet uses a different one.
POOL_MANAGER_ADDRESS=0x000000000004444c5dc75cB358380D2e3dE08A90

# OKLink is X Layer's block explorer (Etherscan-equivalent) — needed for
# `forge verify-contract --verifier oklink`
OKLINK_API_KEY=your_oklink_api_key

# Filled in after DeployMockTokens.s.sol runs
MOCK_USDX_ADDRESS=
MOCK_USDY_ADDRESS=

# Filled in after DeployHook.s.sol runs
HOOK_ADDRESS=
POOL_ID=
