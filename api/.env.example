# X Layer testnet — same RPC as contracts/.env
RPC_URL=https://xlayer-testnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Filled in after contracts/script/DeployHook.s.sol runs
HOOK_ADDRESS=
POOL_ID=

PORT=3000

# --- x402 (not wired up yet — you said you don't have OKX Payment SDK) ---
# Leave PAID_MODE=false to run /protection-status as a free A2MCP endpoint,
# which is fully valid for OKX.AI listing (free endpoints just return the
# result, no x402 required). Flip to true once you've installed the OKX
# Payment SDK and filled in the below — see docs/SUBMISSION.md.
PAID_MODE=false
X402_MERCHANT_ID=
X402_PRICE_USDC=0.001
